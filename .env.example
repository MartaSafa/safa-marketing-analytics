# ─── SUPABASE ────────────────────────────────────────────────
# Copia estos valores desde tu proyecto en supabase.com > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Solo en servidor (nunca en el cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── META ADS API ────────────────────────────────────────────
# Meta for Developers > Tu app > Marketing API
META_ACCESS_TOKEN=EAAxxxxxxxxxx
META_AD_ACCOUNT_ID=act_xxxxxxxxxx  # Ej: act_123456789

# ─── GOOGLE ADS API ──────────────────────────────────────────
# Google Cloud Console > APIs > Google Ads API
GOOGLE_ADS_CLIENT_ID=xxxxxxxxxx.apps.googleusercontent.com
GOOGLE_ADS_CLIENT_SECRET=GOCSPX-xxxxxxxxxx
GOOGLE_ADS_REFRESH_TOKEN=1//xxxxxxxxxx
GOOGLE_ADS_DEVELOPER_TOKEN=xxxxxxxxxx
GOOGLE_ADS_CUSTOMER_ID=xxx-xxx-xxxx  # Sin guiones en el código: xxxxxxxxxx

# ─── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ALLOWED_EMAIL_DOMAIN=safamotor.es  # Solo este dominio puede entrar

# ─── CRON SECRET ─────────────────────────────────────────────
# Genera uno aleatorio: openssl rand -hex 32
CRON_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
